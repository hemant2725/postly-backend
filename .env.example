# Postly environment template
# Copy this file to `.env` and replace placeholder values before running the app.

# Runtime mode

# Allowed values: development | test | production
NODE_ENV=development

# Express server port
PORT=3000


# Core infrastructure

# PostgreSQL connection string used by Prisma and runtime DB access.
# Required.
DATABASE_URL=postgresql://postgres:password@localhost:5432/postly

# Redis connection string used for:
# 1. BullMQ publish queue
# 2. Telegram conversation state storage
# Required for normal app behavior.
REDIS_URL=redis://localhost:6379


# Auth secrets

# JWT signing secret for access tokens.
# Required. Must be at least 32 characters.
JWT_SECRET=replace-with-a-long-random-access-token-secret

# Reserved signing secret for refresh-token workflows/config validation.
# Required by the app config. Must be at least 32 characters.
JWT_REFRESH_SECRET=replace-with-a-different-long-random-refresh-secret


# Encryption secret

# Base secret used to derive the AES-256-GCM encryption key for:
# - connected social account tokens
# - stored user AI provider keys
# Required. Minimum 16 characters; longer random values are better.
ENCRYPTION_KEY=replace-with-a-long-random-encryption-secret

# AI provider keys

# Optional environment-level OpenAI key.
# Used when the user has not stored a personal OpenAI key in the database.
OPENAI_API_KEY=sk-your-openai-key

# Optional environment-level Groq key.
# Used by the Groq generation path.
GROQ_API_KEY=gsk_your_groq_key

# Optional environment-level Anthropic key.
# Used when the user has not stored a personal Anthropic key in the database.
ANTHROPIC_API_KEY=sk-ant-your-anthropic-key

# Optional override for the Groq model id.
# If omitted, the app defaults to: openai/gpt-oss-120b
GROQ_MODEL=openai/gpt-oss-120b


# Telegram bot

# Telegram bot token from BotFather.
# Required because the bot layer is initialized as part of the app runtime.
TELEGRAM_BOT_TOKEN=1234567890:replace-with-your-telegram-bot-token

# Public base URL for production webhook mode.
# Optional in development. Used only when NODE_ENV=production.
WEBHOOK_URL=https://your-app.onrender.com
