{
  "info": {
    "name": "Postly API",
    "description": "Postly Backend API Collection",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "base_url",
      "value": "http://localhost:3000"
    },
    {
      "key": "token",
      "value": ""
    },
    {
      "key": "refresh_token",
      "value": ""
    },
    {
      "key": "post_id",
      "value": ""
    },
    {
      "key": "social_account_id",
      "value": ""
    }
  ],
  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/register",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\",\n  \"name\": \"John Doe\"\n}"
            }
          }
        },
        {
          "name": "Login",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/login",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"user@example.com\",\n  \"password\": \"password123\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.access_token) {",
                  "  pm.collectionVariables.set('token', json.data.access_token);",
                  "}",
                  "if (json?.data?.refresh_token) {",
                  "  pm.collectionVariables.set('refresh_token', json.data.refresh_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Refresh Token",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/refresh",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "const json = pm.response.json();",
                  "if (json?.data?.access_token) {",
                  "  pm.collectionVariables.set('token', json.data.access_token);",
                  "}",
                  "if (json?.data?.refresh_token) {",
                  "  pm.collectionVariables.set('refresh_token', json.data.refresh_token);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Logout",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/api/auth/logout",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"refresh_token\": \"{{refresh_token}}\"\n}"
            }
          }
        },
        {
          "name": "Get Me",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/auth/me"
          }
        }
      ]
    },
    {
      "name": "User",
      "item": [
        {
          "name": "Get Profile",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/user/profile"
          }
        },
        {
          "name": "Update Profile",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/user/profile",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"name\": \"John Doe\",\n  \"bio\": \"Building with AI\",\n  \"default_tone\": \"professional\",\n  \"default_language\": \"en\"\n}"
            }
          }
        },
        {
          "name": "Add Social Account",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/user/social-accounts",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"platform\": \"linkedin\",\n  \"access_token\": \"platform-access-token\",\n  \"refresh_token\": \"platform-refresh-token\",\n  \"handle\": \"johndoe\"\n}"
            }
          }
        },
        {
          "name": "List Social Accounts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/user/social-accounts"
          }
        },
        {
          "name": "Delete Social Account",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/user/social-accounts/{{social_account_id}}"
          }
        },
        {
          "name": "Update AI Keys",
          "request": {
            "method": "PUT",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/user/ai-keys",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"openai_key\": \"sk-your-openai-key\",\n  \"anthropic_key\": \"sk-ant-your-anthropic-key\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Content",
      "item": [
        {
          "name": "Generate Content",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/content/generate",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idea\": \"Launching our AI content assistant for creators.\",\n  \"post_type\": \"announcement\",\n  \"platforms\": [\"twitter\", \"linkedin\"],\n  \"tone\": \"professional\",\n  \"language\": \"en\",\n  \"model\": \"groq\"\n}"
            }
          }
        }
      ]
    },
    {
      "name": "Posts",
      "item": [
        {
          "name": "Publish Post",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/posts/publish",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idea\": \"Launching our AI content assistant for creators.\",\n  \"post_type\": \"announcement\",\n  \"platforms\": [\"linkedin\"],\n  \"tone\": \"professional\",\n  \"language\": \"en\",\n  \"model\": \"groq\",\n  \"generated\": {\n    \"linkedin\": {\n      \"content\": \"We are excited to launch Postly, an AI-powered content assistant for creators.\",\n      \"char_count\": 101\n    }\n  }\n}"
            }
          }
        },
        {
          "name": "Schedule Post",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              },
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/posts/schedule",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"idea\": \"Tomorrow's product update post.\",\n  \"post_type\": \"educational\",\n  \"platforms\": [\"twitter\", \"threads\"],\n  \"tone\": \"casual\",\n  \"language\": \"en\",\n  \"model\": \"groq\",\n  \"publish_at\": \"2026-05-01T10:00:00.000Z\",\n  \"generated\": {\n    \"twitter\": {\n      \"content\": \"We're shipping a cleaner creator workflow tomorrow. #AI #BuildInPublic\",\n      \"hashtags\": [\"#AI\", \"#BuildInPublic\"]\n    },\n    \"threads\": {\n      \"content\": \"Tomorrow we're shipping a cleaner creator workflow with better publishing support.\"\n    }\n  }\n}"
            }
          }
        },
        {
          "name": "List Posts",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": {
              "raw": "{{base_url}}/api/posts?page=1&limit=10&status=queued&platform=linkedin",
              "host": [
                "{{base_url}}"
              ],
              "path": [
                "api",
                "posts"
              ],
              "query": [
                {
                  "key": "page",
                  "value": "1"
                },
                {
                  "key": "limit",
                  "value": "10"
                },
                {
                  "key": "status",
                  "value": "queued"
                },
                {
                  "key": "platform",
                  "value": "linkedin"
                }
              ]
            }
          }
        },
        {
          "name": "Get Post By Id",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/posts/{{post_id}}"
          }
        },
        {
          "name": "Retry Failed Post Platforms",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/posts/{{post_id}}/retry"
          }
        },
        {
          "name": "Cancel Post",
          "request": {
            "method": "DELETE",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/posts/{{post_id}}"
          }
        }
      ]
    },
    {
      "name": "Dashboard",
      "item": [
        {
          "name": "Get Stats",
          "request": {
            "method": "GET",
            "header": [
              {
                "key": "Authorization",
                "value": "Bearer {{token}}"
              }
            ],
            "url": "{{base_url}}/api/dashboard/stats"
          }
        }
      ]
    },
    {
      "name": "System",
      "item": [
        {
          "name": "Health Check",
          "request": {
            "method": "GET",
            "url": "{{base_url}}/health"
          }
        },
        {
          "name": "Telegram Webhook",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": "{{base_url}}/webhook/telegram",
            "body": {
              "mode": "raw",
              "raw": "{\n  \"update_id\": 123456789,\n  \"message\": {\n    \"message_id\": 1,\n    \"date\": 1710000000,\n    \"chat\": {\n      \"id\": 123456789,\n      \"type\": \"private\"\n    },\n    \"text\": \"/start\"\n  }\n}"
            }
          }
        }
      ]
    }
  ]
}
