{
  "name": "postly-backend",
  "version": "1.0.0",
  "description": "Backend for Postly - AI multi-platform content publishing system",
  "type": "module",
  "main": "src/server.js",
  "scripts": {
    "dev": "node src/server.js",
    "start": "node src/server.js",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js --runInBand --detectOpenHandles"
  },
"jest": {
  "testEnvironment": "node",
  "setupFilesAfterEnv": [
    "<rootDir>/src/tests/setup.js"
  ],
  "moduleNameMapper": {
    "^(\\.{1,2}/.*)\\.js$": "$1"
  },
    "transform": {
      "^.+\\.js$": "babel-jest"
    },
    "transformIgnorePatterns": [
      "node_modules/(?!(node-telegram-bot-api|bullmq|ioredis)/)"
    ]
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/hemant2725/postly-backend.git"
  },
  "keywords": [
    "node",
    "express",
    "backend",
    "ai",
    "telegram"
  ],
  "author": "Hemant Singh",
  "license": "ISC",
  "dependencies": {
    "@anthropic-ai/sdk": "^0.91.1",
    "@prisma/client": "^5.22.0",
    "axios": "^1.15.2",
    "bcryptjs": "^3.0.3",
    "bullmq": "^5.76.2",
    "cors": "^2.8.5",
    "dotenv": "^17.4.2",
    "express": "^5.2.1",
    "ioredis": "^5.10.1",
    "jsonwebtoken": "^9.0.3",
    "node-telegram-bot-api": "^0.67.0",
    "openai": "^6.34.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@types/jest": "^30.0.0",
    "babel-jest": "^30.3.0",
    "jest": "^30.3.0",
    "nodemon": "^3.1.14",
    "prisma": "^5.22.0",
    "supertest": "^7.2.2"
  }
}
